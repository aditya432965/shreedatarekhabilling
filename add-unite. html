<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Units | Shree Datarekha Enterprises</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        :root {
            --primary: #007ea7;
            --secondary: #001f3f;
            --accent: #10b981;
            --danger: #ef4444;
            --bg: #0b0f19;
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family: 'Segoe UI', sans-serif; }
        body { background: var(--bg); color: white; padding: 15px; min-height: 100vh; }

        .container { max-width: 500px; margin: 0 auto; }

        .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
        .btn-back { color: #a0d8ef; text-decoration: none; font-size: 14px; }

        .card { background: rgba(255,255,255,0.05); padding: 20px; border-radius: 12px; border-left: 5px solid var(--primary); margin-bottom: 20px; }
        
        .input-group { display: flex; flex-direction: column; gap: 8px; }
        label { font-size: 12px; color: #a0d8ef; }
        input { padding: 12px; border-radius: 8px; border: 1px solid #334155; background: #1e293b; color: white; outline: none; width: 100%; }
        
        .btn-save { background: var(--accent); color: white; border: none; padding: 12px; border-radius: 8px; cursor: pointer; font-weight: 600; margin-top: 10px; width: 100%; }

        .list-section { background: #1e293b; border-radius: 12px; overflow: hidden; }
        .unit-item { display: flex; justify-content: space-between; align-items: center; padding: 15px; border-bottom: 1px solid #334155; }
        .unit-item:last-child { border-bottom: none; }
        .unit-name { font-weight: 500; font-size: 16px; text-transform: uppercase; }
        
        .btn-delete { background: var(--danger); color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; }

        /* Empty State */
        .empty { padding: 20px; text-align: center; color: #94a3b8; font-size: 14px; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h2 style="color: var(--primary);">Manage Units</h2>
        <a href="index.html" class="btn-back">← Back</a>
    </div>

    <div class="card">
        <div class="input-group">
            <label>Unit Name (e.g., KG, BOX, PCS)</label>
            <input type="text" id="unitInput" placeholder="Enter unit name...">
        </div>
        <button class="btn-save" onclick="saveUnit()">Save Unit</button>
    </div>

    <div class="list-section" id="unitList">
        <div class="empty">Loading units...</div>
    </div>
</div>

<script type="module">
    import { db } from './firebase-config.js';
    import { collection, addDoc, onSnapshot, deleteDoc, doc, query, orderBy } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

    const unitInput = document.getElementById('unitInput');
    const unitListDiv = document.getElementById('unitList');

    // 1. Listen for Real-time Updates
    const q = query(collection(db, "units"), orderBy("name", "asc"));
    onSnapshot(q, (snapshot) => {
        unitListDiv.innerHTML = "";
        if (snapshot.empty) {
            unitListDiv.innerHTML = '<div class="empty">No units added yet.</div>';
            return;
        }

        snapshot.forEach((docSnap) => {
            const unit = docSnap.data();
            const id = docSnap.id;

            const div = document.createElement('div');
            div.className = 'unit-item';
            div.innerHTML = `
                <span class="unit-name">${unit.name}</span>
                <button class="btn-delete" onclick="deleteUnit('${id}')">Delete</button>
            `;
            unitListDiv.appendChild(div);
        });
    });

    // 2. Save Unit
    window.saveUnit = async function() {
        const val = unitInput.value.trim().toUpperCase();
        if (!val) return alert("Please enter a unit name!");

        try {
            await addDoc(collection(db, "units"), {
                name: val,
                createdAt: new Date()
            });
            unitInput.value = "";
        } catch (e) {
            alert("Error saving unit: " + e.message);
        }
    };

    // 3. Delete Unit
    window.deleteUnit = async function(id) {
        if (confirm("Are you sure you want to delete this unit?")) {
            try {
                await deleteDoc(doc(db, "units", id));
            } catch (e) {
                alert("Error deleting: " + e.message);
            }
        }
    };
</script>

</body>
</html>
